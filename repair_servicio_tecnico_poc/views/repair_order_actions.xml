<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_repair_order_field_service_poc" model="ir.actions.act_window">
        <field name="name">Servicio Técnico F/C (POC)</field>
        <field name="res_model">repair.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('sale_order_id', '!=', False)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Órdenes de reparación vinculadas a una venta de servicio técnico.
                Usá la acción "Crear caso de prueba" desde el menú de acciones
                (⚙) de esta lista para generar un caso de punta a punta.
            </p>
        </field>
    </record>

    <record id="ir_actions_server_poc_create_demo" model="ir.actions.server">
        <field name="name">POC: crear caso de prueba (equipo + venta + orden)</field>
        <field name="model_id" ref="repair.model_repair_order"/>
        <field name="binding_model_id" ref="repair.model_repair_order"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = model.poc_create_test_field_service_order()</field>
    </record>

    <menuitem id="menu_repair_order_field_service_poc"
              name="Servicio Técnico F/C (POC)"
              parent="repair.menu_repair_order"
              action="action_repair_order_field_service_poc"
              sequence="30"/>

</odoo>
