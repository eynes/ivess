<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="repair_order_advance_stage_wizard_form" model="ir.ui.view">
        <field name="name">repair.order.advance.stage.wizard.form</field>
        <field name="model">repair.order.advance.stage.wizard</field>
        <field name="arch" type="xml">
            <form string="Avanzar Etapa">
                <group>
                    <field name="repair_id" readonly="1"/>
                    <field name="current_stage" readonly="1"/>
                    <field name="target_stage_id" required="1"/>
                </group>
                <footer>
                    <button name="action_advance_stage"
                            type="object"
                            string="Avanzar"
                            class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
