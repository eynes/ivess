<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="repair_order_revert_stage_wizard_form" model="ir.ui.view">
        <field name="name">repair.order.revert.stage.wizard.form</field>
        <field name="model">repair.order.revert.stage.wizard</field>
        <field name="arch" type="xml">
            <form string="Revertir Etapa">
                <group>
                    <field name="repair_id" readonly="1"/>
                    <field name="current_stage" readonly="1"/>
                    <field name="target_stage"/>
                </group>
                <footer>
                    <button name="action_revert_stage"
                            type="object"
                            string="Revertir"
                            class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_repair_order_revert_stage_wizard" model="ir.actions.act_window">
        <field name="name">Revertir Etapa</field>
        <field name="res_model">repair.order.revert.stage.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="repair.model_repair_order"/>
    </record>

</odoo>
