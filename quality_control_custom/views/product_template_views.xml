<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view_inherit_qcc" model="ir.ui.view">
        <field name="name">product.template.form.inherit.quality_control_custom</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='inventory']" position="after">
                <page string="Reparaciones" name="repair_settings">
                    <group>
                        <field name="repair_equipment_type"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="product_product_form_view_inherit_qcc" model="ir.ui.view">
        <field name="name">product.product.form.inherit.quality_control_custom</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='inventory']" position="after">
                <page string="Reparaciones" name="repair_settings">
                    <group>
                        <field name="repair_equipment_type"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
