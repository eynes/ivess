<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view_inherit_qcc" model="ir.ui.view">
        <field name="name">product.template.form.inherit.quality_control_custom</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_general']" position="after">
                <group string="Reparaciones" name="repair_equipment_group">
                    <field name="repair_equipment_type"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
