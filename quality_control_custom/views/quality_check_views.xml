<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="quality_check_view_form_inherit_qcc" model="ir.ui.view">
        <field name="name">quality.check.form.inherit.quality_control_custom</field>
        <field name="model">quality.check</field>
        <field name="inherit_id" ref="quality_control.quality_check_view_form"/>
        <field name="arch" type="xml">
            <!-- Ocultar statusbar del header -->
            <xpath expr="//header/field[@name='quality_state']" position="replace"/>

            <!-- Agregar selection_badge debajo del button_box -->
            <!--<xpath expr="//div[@name='button_box']" position="after">
                <div class="oe_title mb-3">
                    <field name="quality_state" widget="selection_badge" readonly="1"/>
                </div>
            </xpath>-->

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_auto_repair"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-wrench"
                        invisible="not repair_id">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Orden de Reparación</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
