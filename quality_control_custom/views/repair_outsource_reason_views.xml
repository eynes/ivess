<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_repair_outsource_reason_list" model="ir.ui.view">
        <field name="name">repair.outsource.reason.list</field>
        <field name="model">repair.outsource.reason</field>
        <field name="arch" type="xml">
            <list string="Razones de Tercerización" editable="bottom">
                <field name="name"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_repair_outsource_reason_form" model="ir.ui.view">
        <field name="name">repair.outsource.reason.form</field>
        <field name="model">repair.outsource.reason</field>
        <field name="arch" type="xml">
            <form string="Razón de Tercerización">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_repair_outsource_reason" model="ir.actions.act_window">
        <field name="name">Razones de Tercerización</field>
        <field name="res_model">repair.outsource.reason</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
    </record>

    <menuitem id="menu_repair_outsource_reason"
              name="Razones de Tercerización"
              parent="repair.repair_menu_config"
              action="action_repair_outsource_reason"
              sequence="15"
              groups="stock.group_stock_manager"/>

</odoo>
