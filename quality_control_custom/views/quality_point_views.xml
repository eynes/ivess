<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_quality_point_form_inherit_qcc" model="ir.ui.view">
        <field name="name">quality.point.form.inherit.quality_control_custom</field>
        <field name="model">quality.point</field>
        <field name="inherit_id" ref="quality.quality_point_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='failure_location_ids']" position="after">
                <field name="is_frio_calor"/>
            </xpath>
        </field>
    </record>

</odoo>
