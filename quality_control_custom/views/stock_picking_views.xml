<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_picking_form_inherit_qcc" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.quality_control_custom</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_repair_orders"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-wrench"
                        invisible="repair_order_count == 0">
                    <field name="repair_order_count" widget="statinfo" string="Reparaciones"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
