<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="quality_control_custom.RepairBarcodeScanner">
        <div class="o_repair_barcode_scanner d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh; padding: 40px;">
            <div class="text-center mb-4">
                <i class="fa fa-barcode" style="font-size: 80px; color: #875a7b;"/>
                <h2 class="mt-3">Escanear Número de Serie</h2>
                <p class="text-muted">
                    Apunte el lector de código de barras al número de serie del equipo
                    para abrir automáticamente su orden de reparación.
                </p>
            </div>

            <div t-if="state.status === 'waiting'" class="alert alert-info text-center" style="max-width: 450px;">
                <i class="fa fa-info-circle me-2"/>
                Esperando escaneo...
            </div>

            <div t-if="state.status === 'searching'" class="alert alert-secondary text-center" style="max-width: 450px;">
                <i class="fa fa-spinner fa-spin me-2"/>
                Buscando orden para: <strong t-esc="state.lastScanned"/>
            </div>

            <div t-if="state.status === 'not_found'" class="alert alert-warning text-center" style="max-width: 450px;">
                <i class="fa fa-exclamation-triangle me-2"/>
                No se encontró orden para: <strong t-esc="state.lastScanned"/>
                <div class="mt-2 small text-muted">Puede volver a escanear otro número de serie.</div>
            </div>

            <div t-if="state.status === 'found'" class="alert alert-success text-center" style="max-width: 450px;">
                <i class="fa fa-check me-2"/>
                Abriendo orden de reparación...
            </div>
        </div>
    </t>
</templates>
