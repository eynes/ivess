<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="maintenance_team_view_tree" model="ir.ui.view">
        <field name="name">maintenance.team.view.tree</field>
        <field name="model">maintenance.team</field>
        <field name="inherit_id" ref="maintenance.maintenance_team_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_workshop"/>
                <field name="is_internal_maintenance"/>
            </xpath>
        </field>
    </record>
</odoo>