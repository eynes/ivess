<odoo>
    <template id="report_etiqueta_template">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="product">
                <div class="page"
                    style="width: 100%; height: 100%; text-align: center; font-family: sans-serif;">

                    <div
                        style="font-weight: bold; font-size: 12px; border: 1px solid black; margin-bottom: 2px;">
                        <span t-field="product.default_code" />
                    </div>

                    <div
                        style="font-size: 10px; margin-bottom: 2px; height: 25px; overflow: hidden;">
                        <span t-field="product.name" />
                    </div>

                    <!--<div
                    style="font-size: 10px; margin-bottom: 4px;">
                        <t t-esc="product.x_pasillo"/> - <t t-esc="product.x_estante"/> - <t t-esc="product.x_cajon"/>
                    </div> TBD-->

                    <!--Código de barra-->
                    <div style="margin-bottom: 2px;">
                        <t t-if="product.default_code">
                            <div t-out="product.default_code"
                                style="padding:0;"
                                t-options="{'widget': 'barcode', 'quiet': 0, 'symbology': 'auto', 'img_style': 'width:100%; height:35px;'}" />

                            <table style="width: 100%; border-collapse: collapse; margin-top: 2px;">
                                <tr>
                                    <t t-foreach="product.default_code" t-as="char">
                                        <td
                                            style="padding: 0; text-align: center; font-size: 10px; font-weight: bold;">
                                            <span t-out="char" />
                                        </td>
                                    </t>
                                </tr>
                            </table>
                        </t>
                    </div>
                    <div style="font-weight: bold; font-size: 11px;">
                        <span t-field="product.categ_id.name" />
                    </div>

                </div>
            </t>
        </t>
    </template>
</odoo>
