<odoo>
    <record id="res_config_settings_view_form_stock_request_route" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.stock.request.route</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock_request.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='stock_request']" position="inside">
                <block title="Configuración de Rutas" id="stock_request_route_config">
                    <setting help="Selecciona la ruta que se usará por defecto en las solicitudes">
                        <field name="manually_set_route_id"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
