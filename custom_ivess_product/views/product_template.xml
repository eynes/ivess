<odoo>
    <record id="product_template_form_view_ivess_inherit" model="ir.ui.view">
        <field name="name">product.template.ivess.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <field name="categ_id" position="after">
                <field name="state"/>
                <field name="abbreviation" invisible="product_variant_count &gt; 1"/>
                <field name="order"/>
                <field name="is_returnable"/>
            </field>
        </field>
    </record>

    <record id="product_template_form_view_sales_tab_ivess_inherit" model="ir.ui.view">
        <field name="name">product.template.form.sales.tab.ivess.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <page name="sales" position="inside">
                <group name="show_in_app_group">
                    <field name="show_in_app"/>
                </group>
            </page>
        </field>
    </record>

     <record id="product_template_only_form_view_ivess_inherit" model="ir.ui.view">
        <field name="name">product.template.only.form.view.ivess.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <field name="default_code" position="attributes">
                <attribute name="readonly">1</attribute>
            </field>
        </field>
    </record>
</odoo>
