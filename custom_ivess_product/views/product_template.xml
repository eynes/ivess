<odoo>
    <record id="product_template_form_view_ivess_inherit" model="ir.ui.view">
        <field name="name">product.template.ivess.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <field name="categ_id" position="after">
                <field name="state"/>
            </field>
        </field>
    </record>


     <record id="product_template_only_form_view_ivess_inherit" model="ir.ui.view">
        <field name="name">product.template.only.form.view.ivess.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <field name="default_code" position="attributes">
                <attribute name="readonly">1</attribute>
            </field>
        </field>
    </record>

    <record id="action_report_etiqueta_personalizada" model="ir.actions.report">
        <field name="name">Etiqueta Personalizada</field>
        <field name="model">product.template</field> <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_ivess_product.report_etiqueta_template</field>
        <field name="report_file">custom_ivess_product.report_etiqueta_template</field>
        <field name="paperformat_id" ref="custom_ivess_product.paperformat_etiqueta_producto"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
