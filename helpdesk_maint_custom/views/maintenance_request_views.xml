<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="maintenance_request_view_form_inherit_equipment_not_required" model="ir.ui.view">
        <field name="name">maintenance.request.form.inherit.equipment.not.required</field>
        <field name="inherit_id" ref="mrp_maintenance.maintenance_request_view_form_inherit_mrp"/>
        <field name="model">maintenance.request</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='equipment_id']" position="attributes">
                <attribute name="required">maintenance_for == 'equipment' and not ticket_id</attribute>
            </xpath>
        </field>
    </record>

    <record id="maintenance_request_view_form_inherit_maint_custom" model="ir.ui.view">
        <field name="name">maintenance.request.form.inherit.maint.custom</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_request_view_form"/>
        <field name="model">maintenance.request</field>
        <field name="arch" type="xml">
            <!-- Materials tab -->
            <xpath expr="//notebook" position="inside">
                <page string="Materiales" name="maint_materials">
                    <field name="material_ids" widget="one2many">
                        <list string="Materiales" editable="bottom">
                            <control>
                                <create string="Agregar un insumo"/>
                            </control>
                            <field name="product_id" required="1"/>
                            <field name="description" optional="show"/>
                            <field name="product_uom_qty" string="Demanda"/>
                            <field name="quantity" string="Cantidad"/>
                            <field name="product_uom" options="{'no_open': True, 'no_create': True}" widget="many2one_uom"/>
                            <field name="lot_id"
                                groups="stock.group_production_lot"
                                domain="[('product_id', '=', product_id)]"
                                optional="show"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
