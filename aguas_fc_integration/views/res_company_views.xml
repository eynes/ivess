<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_aguas_fc" model="ir.ui.view">
        <field name="name">res.company.form.inherit.aguas.fc</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <separator string="Integración Aguas FC"/>
                <field name="aguas_fc_taller_location_id"/>
                <field name="aguas_fc_picking_type_id"/>
                <field name="aguas_fc_product_id"/>
            </xpath>
        </field>
    </record>
</odoo>
