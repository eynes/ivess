<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_partner_form_inherit_ivess_partner_custom" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.ivess.partner.custom</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='accounting']" position="inside">
                <group name="group_requiere_comprobante">
                    <field name="requiere_comprobante"/>
                </group>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="total_invoiced"/>
                <field name="unbilled_balance"/>
                <field name="final_balance"/>
            </xpath>
        </field>
    </record>
</odoo>
