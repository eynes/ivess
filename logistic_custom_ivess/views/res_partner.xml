<odoo>
    <record id="view_partner_form_inherit_sales_purchases" model="ir.ui.view">
        <field name="name">partner.form.inherit.sales.purchases</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
<button class="oe_stat_button" type="object" name="action_open_water_containers" icon="fa-cube">
                    <field string="Envases" name="qty_water_containers" widget="statinfo"/>
                </button>
                <button class="oe_stat_button" type="object" name="action_open_frio_calor_containers" icon="fa-thermometer">
                    <field string="Equipos F/C" name="qty_frio_calor" widget="statinfo"/>
                </button>
                <button class="oe_stat_button" type="object" name="action_open_water_consumption" icon="fa-list">
                    <field string="Consumo de agua historico" name="qty_water_consumption" widget="statinfo"/>
                </button>
            </div>
            <xpath expr="//field[@name='company_type'][@widget='radio']" position="after">
                <div class="d-flex gap-3 mt-1">
                    <div class="d-flex align-items-center gap-1">
                        <field name="is_customer" nolabel="1"/>
                        <label for="is_customer" string="Es Cliente"/>
                    </div>
                    <div class="d-flex align-items-center gap-1">
                        <field name="is_supplier" nolabel="1"/>
                        <label for="is_supplier" string="Es Proveedor"/>
                    </div>
                </div>
            </xpath>
            <xpath expr="//span[@name='address_name']" position="before">
                <field name="mobile_number" class="w-100" widget="phone" placeholder="Celular" help="Número de teléfono móvil"/>
                <field name="address_details" help="Observaciones sobre la dirección del cliente para facilitar la identificación"/>
            </xpath>
            <xpath expr="//field[@name='express_id']" position="before">
                <field name="state" />
                <field name="date_from" invisible="state != 'holidays'"/>
                <field name="date_to" invisible="state != 'holidays'"/>
                <field name="current_month_water_liters"/>
                <field name="current_year_water_liters"/>
                <field name="registration_channel_id"/>
                <field name="customer_code" invisible="not is_customer"/>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="is_important_client"/>
            </xpath>
            <xpath expr="//page[@name='sales_purchases']" position="inside">
                <group invisible="not id">
                    <group name="group_route" string="Recorrido">
                        <field name="partner_type_id"/>
                        <field name="distribution" invisible="1"/>
                        <field name="distributions_ids">
                            <list>
                                <field name="distribution"/>
                                <field name="visit_day"/>
                                <field name="frequency" required="1"/>
                                <field name="last_visit_date" readonly="1"/>
                                <field name="message_type" optional="show"/>
                                <button name="action_open_message_wizard" type="object" icon="fa-envelope" title="Editar Mensaje"/>
                            </list>
                        </field>
                        <field name="average_hour" widget="float_time"/>
                        <field name="visit_hour_from" widget="float_time"/>
                        <field name="visit_hour_to" widget="float_time"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_partner_distribution_form" model="ir.ui.view">
        <field name="name">partner.distribution.form</field>
        <field name="model">partner.distribution</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="distribution"/>
                        <field name="visit_day"/>
                        <field name="frequency" required="1"/>
                        <field name="last_visit_date" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
