<odoo>
    <!-- Tree View -->
    <record id="view_water_container_tree" model="ir.ui.view">
        <field name="name">water.container.tree</field>
        <field name="model">water.container</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="assignment_date"/>
                <field name="return_date"/>
                <field name="state"/>
                <field name="is_nonproductive"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_water_container_form" model="ir.ui.view">
        <field name="name">water.container.form</field>
        <field name="model">water.container</field>
        <field name="arch" type="xml">
            <form string="Water Container">
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_open_outgoing_pickings"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-truck">
                            <field name="count_outgoing_pickings" widget="statinfo" string="Entregas"/>
                        </button>
                        <button name="action_open_incoming_pickings"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-undo">
                            <field name="count_incoming_pickings" widget="statinfo" string="Devoluciones"/>
                        </button>
                    </div>
                    <group>
                        <field name="partner_id" readonly="1"/>
                        <field name="product_id"/>
                        <field name="quantity" readonly="1"/>
                        <field name="assignment_date" required="1"/>
                        <field name="return_date"/>
                        <field name="state" required="1"/>
                        <field name="is_nonproductive"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_water_container" model="ir.actions.act_window">
        <field name="name">Water Containers</field>
        <field name="res_model">water.container</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new water container
            </p>
        </field>
    </record>

    <menuitem id="menu_water_container_main"
              name="Envases"
              parent="crm.crm_menu_config"
              sequence="19"
              action="action_water_container"/>
</odoo>
