<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_delivery_route_region_list" model="ir.ui.view">
        <field name="name">delivery.route.region.list</field>
        <field name="model">delivery.route.region</field>
        <field name="arch" type="xml">
            <list string="Regiones">
                <field name="name"/>
                <field name="supervisor_id"/>
            </list>
        </field>
    </record>

    <record id="view_delivery_route_region_form" model="ir.ui.view">
        <field name="name">delivery.route.region.form</field>
        <field name="model">delivery.route.region</field>
        <field name="arch" type="xml">
            <form string="Región">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="supervisor_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_delivery_route_region" model="ir.actions.act_window">
        <field name="name">Regiones</field>
        <field name="res_model">delivery.route.region</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_delivery_route_region"
              name="Regiones"
              parent="sale.menu_sale_config"
              action="action_delivery_route_region"
              sequence="30"/>
</odoo>
