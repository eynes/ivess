<odoo>
    <record id="view_res_config_settings_form" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.customer.sequence</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='sales_settings_invoicing_policy']" position="after">
                <setting id="minutos_x_convertir_factura_setting" help="Minutos que deben transcurrir para convertir a factura">
                    <field name="minutos_x_convertir_factura" widget="float_time"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>