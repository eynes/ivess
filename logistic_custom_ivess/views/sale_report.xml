<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sale_report_view_list_ivess" model="ir.ui.view">
        <field name="name">sale.report.view.list.ivess</field>
        <field name="model">sale.report</field>
        <field name="inherit_id" ref="sale.sale_report_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="before">
                <field name="allow_free_of_charge" optional="show"/>
                <field name="location_id" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
