<odoo>
    <record id="view_delivery_route_number_message_form" model="ir.ui.view">
        <field name="name">delivery.route.number.message.form</field>
        <field name="model">delivery.route.number.message</field>
        <field name="arch" type="xml">
            <form string="Mensaje General por Reparto">
                <sheet>
                    <group>
                        <field name="delivery_route_number_ids" widget="many2many_tags"
                                invisible="apply_to_all"
                                required="not apply_to_all"/>
                        <field name="message_text" placeholder="Escriba el mensaje aquí..."/>
                        <field name="apply_to_all"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_delivery_route_number_message_list" model="ir.ui.view">
        <field name="name">delivery.route.number.message.list</field>
        <field name="model">delivery.route.number.message</field>
        <field name="arch" type="xml">
            <list string="Historial de Mensajes">
                <field name="message_text"/>
                <field name="apply_to_all"/>
                <field name="delivery_route_number_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="action_delivery_route_number_message" model="ir.actions.act_window">
        <field name="name">Historial de Mensajes</field>
        <field name="res_model">delivery.route.number.message</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_delivery_route_number_message_history"
            name="Historial de Mensajes"
            parent="menu_delivery_route_root"
            sequence="16"
            action="action_delivery_route_number_message" />
</odoo>
