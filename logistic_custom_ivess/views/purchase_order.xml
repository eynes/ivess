<odoo>
    <record id="view_custom_purchase_order_form_inherit" model="ir.ui.view">
        <field name="name">purchase.custom.order.form.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="after">
                <field name="internal_notes" column_invisible="False"/>
            </xpath>
        </field>
    </record>
</odoo>
