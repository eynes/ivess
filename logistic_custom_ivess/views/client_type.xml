<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_client_type_tree" model="ir.ui.view">
        <field name="name">client.type.tree</field>
        <field name="model">client.type</field>
        <field name="arch" type="xml">
            <list string="Client Types">
                <field name="code"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_client_type_form" model="ir.ui.view">
        <field name="name">client.type.form</field>
        <field name="model">client.type</field>
        <field name="arch" type="xml">
            <form string="Client Type">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_client_type" model="ir.actions.act_window">
        <field name="name">Client Types</field>
        <field name="res_model">client.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Client Type
            </p>
        </field>
    </record>

    <menuitem id="menu_client_type" name="Client Types"
              parent="contacts.res_partner_menu_config" action="action_client_type"
              sequence="1"/>
</odoo>
