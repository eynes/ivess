<odoo>
    <record id="view_visit_status_form" model="ir.ui.view">
        <field name="name">visit.status.form</field>
        <field name="model">visit.status</field>
        <field name="arch" type="xml">
            <form string="Visit Status">
                <sheet>
                    <group>
                        <field name="status_name"/>
                        <field name="requires_reason"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_visit_status_tree" model="ir.ui.view">
        <field name="name">visit.status.tree</field>
        <field name="model">visit.status</field>
        <field name="arch" type="xml">
            <list string="Visit Statuses">
                <field name="status_name"/>
                <field name="requires_reason"/>
            </list>
        </field>
    </record>

    <record id="action_visit_status" model="ir.actions.act_window">
        <field name="name">Visit Statuses</field>
        <field name="res_model">visit.status</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
