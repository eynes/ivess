    <record id="view_move_form_inherit_add_m2m" model="ir.ui.view">
        <field name="name">account.move.form.inherit.add.m2m</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/> <!-- Formulario general -->
        <field name="arch" type="xml">
        <xpath expr="//page[@name='other_info']" position="inside">
            <div>
                <separator string="Repartos"/>
                <group>
                </group>
                <field name="delivery_route_ids" nolabel="1" invisible="move_type not in ['out_invoice', 'out_refund', 'out_receipt']">
                    <list>
                        <field name="name"/>
                        <field name="truck_id"/>
                        <field name="delivery_person_id"/>
                        <field name="delivery_date"/>
                        <field name="state" />
                    </list>
                </field>
            </div>
        </xpath>
        </field>
    </record>
</odoo>
