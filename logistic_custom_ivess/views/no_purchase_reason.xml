<odoo>

    <record id="action_no_purchase_reason_list" model="ir.actions.act_window">
        <field name="name">No Purchase Reasons</field>
        <field name="res_model">no.purchase.reason</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_no_purchase_reason_tree" model="ir.ui.view">
        <field name="name">no.purchase.reason.tree</field>
        <field name="model">no.purchase.reason</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="reason"/>
                <field name="is_rake"/>
                <field name="order"/>
            </list>
        </field>
    </record>

    <record id="view_no_purchase_reason_form" model="ir.ui.view">
        <field name="name">no.purchase.reason.form</field>
        <field name="model">no.purchase.reason</field>
        <field name="arch" type="xml">
            <form string="Reason for Not Purchasing">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="reason"/>
                            <field name="is_rake"/>
                            <field name="order"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
