<odoo>
    <record id="logistic_product_template_form_view" model="ir.ui.view">
        <field name="name">logistic.product.template.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="inside">
                <group name="logistic_sale">
                    <group name="name">
                        <field name="allow_free_of_charge"/>
                        <field name="liter_quantity"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>