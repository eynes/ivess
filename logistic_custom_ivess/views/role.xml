<odoo>
     <record id="view_roles_form" model="ir.ui.view">
        <field name="name">roles.form</field>
        <field name="model">role</field>
        <field name="arch" type="xml">
            <form string="Role">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_roles_tree" model="ir.ui.view">
        <field name="name">roles.tree</field>
        <field name="model">role</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_roles" model="ir.actions.act_window">
        <field name="name">Roles</field>
        <field name="res_model">role</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
