<odoo>
    <record id="view_company_form_inherit_customer_sequence" model="ir.ui.view">
        <field name="name">res.company.form.inherit.customer.sequence</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="customer_sequence_id"/>
            </xpath>
        </field>
    </record>
</odoo>
