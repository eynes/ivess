<odoo>
    <record id="view_res_partner_message_wizard_form" model="ir.ui.view">
        <field name="name">res.partner.message.wizard.form</field>
        <field name="model">res.partner.message.wizard</field>
        <field name="arch" type="xml">
            <form string="Mensaje al Cliente">
                <group>
                    <field name="partner_distribution_id" invisible="1"/>
                    <field name="message_type"/>
                    <field name="message_text" placeholder="Escriba el mensaje aquí..."/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_res_partner_message_wizard" model="ir.actions.act_window">
        <field name="name">Mensaje al Cliente</field>
        <field name="res_model">res.partner.message.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
