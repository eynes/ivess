<odoo>
    <record id="view_delivery_route_number_message_wizard_form" model="ir.ui.view">
        <field name="name">delivery.route.number.message.wizard.form</field>
        <field name="model">delivery.route.number.message.wizard</field>
        <field name="arch" type="xml">
            <form string="Mensaje General por Reparto">
                <group>
                    <field name="delivery_route_number_ids" widget="many2many_tags"
                           invisible="apply_to_all"
                           required="not apply_to_all"/>
                    <field name="message_text" placeholder="Escriba el mensaje aquí..."/>
                    <field name="apply_to_all"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_delivery_route_number_message_wizard" model="ir.actions.act_window">
        <field name="name">Mensajes</field>
        <field name="res_model">delivery.route.number.message.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_delivery_route_number_message"
            name="Mensajes"
            parent="menu_delivery_route_root"
            sequence="15"
            action="action_delivery_route_number_message_wizard" />
</odoo>
