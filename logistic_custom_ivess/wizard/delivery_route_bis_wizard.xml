<odoo>
    <record id="view_delivery_route_bis_wizard_form" model="ir.ui.view">
        <field name="name">delivery.route.bis.wizard.form</field>
        <field name="model">delivery.route.bis.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear Ruta Bis">
                <group>
                    <field name="route_id" invisible="1"/>
                    <field name="delivery_number_id"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
